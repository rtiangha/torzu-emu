{
    "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg-tool/main/docs/vcpkg.schema.json",
    "name": "torzu",
    "builtin-baseline": "b2cb0da531c2f1f740045bfe7c4dac59f0b2b69c",
    "version": "1.0",
    "dependencies": [
        "boost",
        "fmt",
        "lz4",
        "nlohmann-json",
        "zlib",
        "zstd"
    ],
    "features": {
        "torzu-tests": {
            "description": "Compile tests",
            "dependencies": [ "catch2" ]
        },
        "web-service": {
            "description": "Enable web services (telemetry, etc.)",
            "dependencies": [
                {
                    "name": "openssl",
                    "platform": "windows"
                }
            ]
        },
        "android": {
            "description": "Enable Android dependencies",
            "dependencies": [
                {
                    "name": "oboe",
                    "platform": "android"
                }
            ]
        }
    },
    "overrides": [
        {
            "name": "catch2",
            "version": "3.7.1"
        },
        {
            "name": "fmt",
            "version": "11.0.2"
        },
        {
            "name": "boost",
            "version": "1.85.0"
        }
    ]
}
